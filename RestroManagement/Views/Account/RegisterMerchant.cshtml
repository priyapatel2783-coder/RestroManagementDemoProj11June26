@model RestroManagement.ViewModels.MerchantRegistrationViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restaurant Registration - RestroManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/registermerchant.css" asp-append-version="true" />
</head>
<body>
    <div class="reg-container">
        <div class="reg-sidebar">
            <h2>Partner with Restro</h2>
            <p>Reach more customers and grow your business with our powerful management platform.</p>
            
            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Online Visibility</strong>
                    <div class="small opacity-75">Get discovered by thousands of food lovers.</div>
                </div>
            </div>

            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Order Management</strong>
                    <div class="small opacity-75">Streamlined tools to handle your daily operations.</div>
                </div>
            </div>

            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Rich Analytics</strong>
                    <div class="small opacity-75">Understand your business trends and growth.</div>
                </div>
            </div>
        </div>

        <div class="reg-content">
            <div class="brand-logo">
                <h1>Restro</h1>
            </div>

            <form asp-action="RegisterMerchant" method="post">
                <div asp-validation-summary="ModelOnly" class="error-summary small" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="section-header">Restaurant Details</div>
                
                <div class="row">
                    <div class="col-md-7 form-group">
                        <label asp-for="StoreName" class="form-label required">Restaurant Name</label>
                        <input asp-for="StoreName" class="form-control" placeholder="e.g. The Grand Kitchen" />
                        <span asp-validation-for="StoreName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5 form-group">
                        <label asp-for="BusinessType" class="form-label required">Type</label>
                        <select asp-for="BusinessType" class="form-select">
                            <option value="">Select Type</option>
                            <option value="Dine-in">Dine-in</option>
                            <option value="Cafe">Cafe</option>
                            <option value="Bakery">Bakery</option>
                            <option value="Quick Service">Quick Service</option>
                        </select>
                        <span asp-validation-for="BusinessType" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="StoreAddress" class="form-label required">Restaurant Address</label>
                    <input asp-for="StoreAddress" class="form-control" placeholder="Full address" />
                    <span asp-validation-for="StoreAddress" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BusinessLicense" class="form-label required"></label>
                    <input asp-for="BusinessLicense" class="form-control" placeholder="Enter business license" />
                    
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label asp-for="City" class="form-label required">City</label>
                        <input asp-for="City" class="form-control" placeholder="City" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="State" class="form-label required">State</label>
                        <input asp-for="State" class="form-control" placeholder="State" />
                        <span asp-validation-for="State" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="ZipCode" class="form-label required">Zip Code</label>
                        <input asp-for="ZipCode" class="form-control" placeholder="Zip" />
                        <span asp-validation-for="ZipCode" class="text-danger small"></span>
                    </div>
                </div>

                <div class="section-header">Owner Details</div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label asp-for="FName" class="form-label required">First Name</label>
                        <input asp-for="FName" class="form-control" />
                        <span asp-validation-for="FName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 form-group">
                        <label asp-for="LName" class="form-label required">Last Name</label>
                        <input asp-for="LName" class="form-control" />
                        <span asp-validation-for="LName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-7 form-group">
                        <label asp-for="Email" class="form-label required">Owner Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5 form-group">
                        <label asp-for="PhoneNumber" class="form-label required">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label asp-for="Password" class="form-label required">Password</label>
                      <div class="input-group">
                            <input asp-for="Password" type="password" class="form-control" id="Password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('Password', 'passwordIcon')">
                             <i class="bi bi-eye" id="passwordIcon"></i>
                            </button>
                      </div>

                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="ConfirmPassword" class="form-label required">Confirm Password</label>
                        <div class="input-group"><input asp-for="ConfirmPassword" type="password"  class="form-control"id="ConfirmPassword" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('ConfirmPassword', 'confirmPasswordIcon')">
                                <i class="bi bi-eye" id="confirmPasswordIcon"></i>
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
                <button type="submit" class="btn-submit">Register My Restaurant</button>
            </form>

            <div class="text-center mt-4 small text-muted">
                Already registered? <a asp-action="Login" class="text-primary text-decoration-none fw-bold">Login here</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePassword(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon = document.getElementById(iconId);

        if (input.type === "password") {
        input.type = "text";
        icon.classList.remove("bi-eye");
        icon.classList.add("bi-eye-slash");
        } else {
        input.type = "password";
        icon.classList.remove("bi-eye-slash");
        icon.classList.add("bi-eye");
        }
        }
    </script>
</body>
</html>
