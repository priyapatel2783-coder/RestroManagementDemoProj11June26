@model RestroManagement.ViewModels.MerchantRegistrationViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restaurant Registration - RestroManagement</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary-color: #ef4f5f;
            --secondary-color: #2d2d2d;
            --text-main: #1c1c1c;
            --text-light: #696969;
            --bg-color: #f8f8f8;
            --accent-green: #4caf50;
        }

        body {
            background-color: var(--bg-color);
            min-height: 100vh;
            font-family: 'Okra', Helvetica, sans-serif;
            margin: 0;
            padding: 40px 0;
        }

        .reg-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            overflow: hidden;
            display: flex;
            animation: fadeIn 0.5s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .reg-sidebar {
            background-color: var(--secondary-color);
            color: white;
            width: 35%;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .reg-sidebar h2 {
            font-size: 32px;
            font-weight: 800;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .reg-sidebar p {
            font-size: 16px;
            opacity: 0.8;
            margin-bottom: 30px;
        }

        .feature-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .feature-item i {
            color: var(--accent-green);
            margin-right: 15px;
            font-size: 20px;
            margin-top: 3px;
        }

        .reg-content {
            flex: 1;
            padding: 40px;
        }

        .brand-logo h1 {
            color: var(--primary-color);
            font-weight: 800;
            font-size: 2rem;
            margin: 0 0 30px 0;
            letter-spacing: -1px;
        }

        .section-header {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-main);
            margin: 25px 0 15px 0;
            padding-bottom: 8px;
            border-bottom: 1px solid #f0f0f0;
        }

        .section-header:first-of-type {
            margin-top: 0;
        }

        .form-group {
            margin-bottom: 15px;
        }

        .form-label {
            display: block;
            margin-bottom: 6px;
            color: var(--text-light);
            font-size: 13px;
            font-weight: 500;
        }

        .form-control, .form-select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #e8e8e8;
            border-radius: 8px;
            font-size: 15px;
            transition: border-color 0.2s;
        }

        .form-control:focus, .form-select:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px rgba(239, 79, 95, 0.1);
        }

        .btn-submit {
            width: 100%;
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 20px;
        }

        .btn-submit:hover {
            background-color: #d83a4a;
        }

        .error-summary {
            background-color: #fff5f6;
            border: 1px solid #ffcfd4;
            color: #d83a4a;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        @@media (max-width: 768px) {
            .reg-container {
                flex-direction: column;
                max-width: 95%;
            }
            .reg-sidebar {
                width: 100%;
                padding: 30px;
            }
            .reg-content {
                padding: 30px;
            }
        }
    </style>
</head>
<body>
    <div class="reg-container">
        <div class="reg-sidebar">
            <h2>Partner with Restro</h2>
            <p>Reach more customers and grow your business with our powerful management platform.</p>
            
            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Online Visibility</strong>
                    <div class="small opacity-75">Get discovered by thousands of food lovers.</div>
                </div>
            </div>

            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Order Management</strong>
                    <div class="small opacity-75">Streamlined tools to handle your daily operations.</div>
                </div>
            </div>

            <div class="feature-item">
                <i class="bi bi-check-circle-fill"></i>
                <div>
                    <strong>Rich Analytics</strong>
                    <div class="small opacity-75">Understand your business trends and growth.</div>
                </div>
            </div>
        </div>

        <div class="reg-content">
            <div class="brand-logo">
                <h1>Restro</h1>
            </div>

            <form asp-action="RegisterMerchant" method="post">
                <div asp-validation-summary="ModelOnly" class="error-summary small" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="section-header">Restaurant Details</div>
                
                <div class="row">
                    <div class="col-md-7 form-group">
                        <label asp-for="StoreName" class="form-label">Restaurant Name</label>
                        <input asp-for="StoreName" class="form-control" placeholder="e.g. The Grand Kitchen" />
                        <span asp-validation-for="StoreName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5 form-group">
                        <label asp-for="BusinessType" class="form-label">Type</label>
                        <select asp-for="BusinessType" class="form-select">
                            <option value="">Select Type</option>
                            <option value="Dine-in">Dine-in</option>
                            <option value="Cafe">Cafe</option>
                            <option value="Bakery">Bakery</option>
                            <option value="Quick Service">Quick Service</option>
                        </select>
                        <span asp-validation-for="BusinessType" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="StoreAddress" class="form-label">Restaurant Address</label>
                    <input asp-for="StoreAddress" class="form-control" placeholder="Full address" />
                    <span asp-validation-for="StoreAddress" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BusinessLicense" class="form-label"></label>
                    <input asp-for="BusinessLicense" class="form-control" placeholder="Enter business license" />
                    
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label asp-for="City" class="form-label">City</label>
                        <input asp-for="City" class="form-control" placeholder="City" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="State" class="form-label">State</label>
                        <input asp-for="State" class="form-control" placeholder="State" />
                        <span asp-validation-for="State" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="ZipCode" class="form-label">Zip Code</label>
                        <input asp-for="ZipCode" class="form-control" placeholder="Zip" />
                        <span asp-validation-for="ZipCode" class="text-danger small"></span>
                    </div>
                </div>

                <div class="section-header">Owner Details</div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label asp-for="FName" class="form-label">First Name</label>
                        <input asp-for="FName" class="form-control" />
                        <span asp-validation-for="FName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 form-group">
                        <label asp-for="LName" class="form-label">Last Name</label>
                        <input asp-for="LName" class="form-control" />
                        <span asp-validation-for="LName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-7 form-group">
                        <label asp-for="Email" class="form-label">Owner Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-5 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 form-group">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Register My Restaurant</button>
            </form>

            <div class="text-center mt-4 small text-muted">
                Already registered? <a asp-action="Login" class="text-primary text-decoration-none fw-bold">Login here</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
