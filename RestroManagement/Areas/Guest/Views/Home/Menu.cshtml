@model List<RestroManagement.DbModels.FoodItem>

@{
    ViewData["Title"] = "Menu";

    // Extract unique categories from model items for the filter pills
    var categories = Model
        .SelectMany(f => f.Categories ?? Enumerable.Empty<RestroManagement.DbModels.FoodItemCategory>())
        .Select(fc => fc.Category)
        .Where(c => c != null)
        .GroupBy(c => c.Id)
        .Select(g => g.First())
        .OrderBy(c => c.DisplayOrder)
        .ToList();
}

<link rel="stylesheet" href="~/css/menu.css" asp-append-version="true" />

<div class="container py-4">
    <!-- Hero Banner -->
    <div class="menu-hero">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1>Our Exquisite Menu</h1>
                <p class="lead">Select your dishes, choose your preferred portion size, adjust quantities, and click "Proceed to Billing" to go to the cart.</p>
            </div>
            <div class="col-md-4 text-end d-none d-md-block">
                <i class="bi bi-egg-fried" style="font-size: 5rem; opacity: 0.15;"></i>
            </div>
        </div>
    </div>

    <!-- Search & Filters / Proceed Section -->
    <form asp-controller="Home" asp-action="AddMultipleToCart" method="post" id="menuForm">

        <div class="search-filter-section">
            <div class="row g-3 align-items-center">
                <!-- Search Input -->
                <div class="col-md-4">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" id="menuSearch" class="form-control search-box" placeholder="Search for dishes..." oninput="filterMenu()" />
                    </div>
                </div>

                <!-- Category Filters -->
                <div class="col-md-4 text-center">

                    <div class="category-pills justify-content-center">
                        <button type="button" class="category-pill active" onclick="selectCategory('All', this)">All</button>
                        @foreach (var cat in categories)
                        {
                            <button type="button" class="category-pill" onclick="selectCategory('@cat.Name', this)">@cat.Name</button>
                        }
                    </div>
                </div>

                <!-- Bulk Checkout Button -->
                <div class="col-md-4 text-md-end">
                    <button type="submit" class="btn btn-secondary btn-lg w-100 py-3 fw-bold" id="btnProceedToCart" disabled style="border-radius: 12px;">
                        <i class="bi bi-cart-check-fill"></i> Proceed to Billing (<span id="selectedCountBadge">0</span>)
                    </button>
                </div>
            </div>
        </div>

        <!-- Menu Grid -->
        <div class="row" id="menuItemsGrid">
            @foreach (var items in Model)
            {
                var itemCategories = string.Join(",", items.Categories?.Select(c => c.Category?.Name).Where(n => n != null) ?? Enumerable.Empty<string>());
                var defaultPortion = items.Portions?.FirstOrDefault();

                <div class="col-lg-3 col-md-6 col-sm-12 mb-4 food-card-container" 
                     data-categories="@itemCategories"
                     data-name="@items.Name.ToLower()"
                     data-desc="@items.Description.ToLower()">

                    <div class="food-card">
                        <!-- Images and Badges -->
                        <div class="food-image-wrapper">
                            @if (items.Images != null && items.Images.Any())
                            {
                                <img src="@items.Images.FirstOrDefault()?.ImageUrl" class="food-image" alt="@items.Name" />
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=500&q=80" class="food-image" alt="@items.Name" />
                            }

                            <!-- Badges Overlay -->
                            <div class="badge-container">
                                @if (items.DietaryPreference == RestroManagement.DbModels.DietaryPreference.Vegetarian)
                                {
                                    <span class="preference-badge veg"><i class="bi bi-circle-fill" style="font-size: 0.6rem;"></i> Veg</span>
                                }
                                else if (items.DietaryPreference == RestroManagement.DbModels.DietaryPreference.NonVegetarian)
                                {
                                    <span class="preference-badge nonveg"><i class="bi bi-triangle-fill" style="font-size: 0.6rem;"></i> Non-Veg</span>
                                }
                                else if (items.DietaryPreference == RestroManagement.DbModels.DietaryPreference.ContainsEgg)
                                {
                                    <span class="preference-badge egg"><i class="bi bi-egg-fill"></i> Egg</span>
                                }
                                else if (items.DietaryPreference == RestroManagement.DbModels.DietaryPreference.Vegan)
                                {
                                    <span class="preference-badge vegan"><i class="bi bi-leaf"></i> Vegan</span>
                                }
                            </div>

                            @if (items.Categories != null && items.Categories.Any())
                            {
                                <span class="category-badge">@items.Categories.FirstOrDefault()?.Category?.Name</span>
                            }
                        </div>

                        <!-- Details -->
                        <div class="food-card-body">
                            <h4 class="food-name">@items.Name</h4>
                            <p class="food-desc">@items.Description</p>

                            <!-- Portions Option Selector -->
                            @if (items.Portions != null && items.Portions.Count > 1)
                            {
                                <div class="mb-3 text-start">
                                    <label class="form-label small text-muted fw-bold mb-1">Select Portion:</label>
                                    <select class="form-select form-select-sm portion-select" onchange="updatePortion(this, '@items.Id')">
                                        @foreach (var portion in items.Portions)
                                        {
                                            <option value="@portion.Name" data-price="@portion.Price">
                                                @portion.Name (₹@portion.Price)
                                            </option>
                                        }
                                    </select>
                                </div>
                            }
                            else if (items.Portions != null && items.Portions.Any())
                            {
                                <div class="mb-3 text-start text-muted small">
                                    <strong>Portion:</strong> @defaultPortion?.Name
                                </div>
                            }

                            <!-- Price and Quantity Control -->
                            <div class="price-qty-row">
                                <span class="food-price" id="price_@items.Id">₹@(defaultPortion?.Price ?? 0)</span>

                                <div class="quantity-box">
                                    <button type="button" class="qty-btn" onclick="updateQuantity('@items.Id', -1)">-</button>
                                    <input type="text" id="qty_@items.Id" name="Quantity" value="0" class="qty-input" readonly />
                                    <button type="button" class="qty-btn" onclick="updateQuantity('@items.Id', 1)">+</button>
                                </div>
                            </div>

                            <!-- Hidden Fields Submitted on Bulk Checkout -->
                            <input type="hidden" name="FoodItemId" value="@items.Id" />
                            <input type="hidden" name="ItemName" value="@items.Name" />
                            <input type="hidden" id="selectedPortion_@items.Id" name="PortionName" value="@(defaultPortion?.Name ?? "Regular")" />
                            <input type="hidden" id="selectedPrice_@items.Id" name="Price" value="@(defaultPortion?.Price ?? 0)" />
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Floating Checkout Button -->
        <button type="submit" class="btn btn-danger btn-lg floating-cart-btn shadow-lg" id="floatingProceedBtn" style="display: none;">
            <i class="bi bi-cart-check-fill"></i> Proceed to Billing (<span id="floatingCountBadge">0</span>)
        </button>

    </form>

    <!-- Empty State -->
    <div id="emptyState" class="empty-state d-none">
        <i class="bi bi-search" style="font-size: 3rem; color: #9CA3AF;"></i>
        <h4 class="mt-3 text-muted">No dishes found</h4>
        <p class="text-muted">Try adjusting your search query or choosing another category filter.</p>
    </div>
</div>

<script>
    let activeCategory = 'All';

    // Portion select change callback
    function updatePortion(selectElement, itemId) {
        let selectedOption = selectElement.options[selectElement.selectedIndex];
        let price = selectedOption.getAttribute('data-price');
        let portionName = selectedOption.value;

        // Update displayed price label
        document.getElementById('price_' + itemId).innerText = '₹' + price;

        // Update hidden form inputs
        document.getElementById('selectedPortion_' + itemId).value = portionName;
        document.getElementById('selectedPrice_' + itemId).value = price;
    }

    // Quantity update logic with visual feedback
    function updateQuantity(id, change) {
        let qtyInput = document.getElementById('qty_' + id);
        if (!qtyInput) return;

        let currentValue = parseInt(qtyInput.value) || 0;
        let newValue = currentValue + change;
        if (newValue < 0) newValue = 0;

        qtyInput.value = newValue;

        recalcGlobalSelection();
    }

    // Recalculates total selected quantity to enable/disable Proceed buttons
    function recalcGlobalSelection() {
        let totalSelected = Array.from(document.querySelectorAll('.qty-input'))
            .reduce((sum, input) => sum + (parseInt(input.value) || 0), 0);

        let topBtn = document.getElementById('btnProceedToCart');
        let floatingBtn = document.getElementById('floatingProceedBtn');

        document.getElementById('selectedCountBadge').innerText = totalSelected;
        document.getElementById('floatingCountBadge').innerText = totalSelected;

        if (totalSelected > 0) {
            // Enable top checkout button
            topBtn.disabled = false;
            topBtn.classList.remove('btn-secondary');
            topBtn.classList.add('btn-danger');

            // Show floating checkout button
            floatingBtn.style.display = 'block';
        } else {
            // Disable top checkout button
            topBtn.disabled = true;
            topBtn.classList.remove('btn-danger');
            topBtn.classList.add('btn-secondary');

            // Hide floating checkout button
            floatingBtn.style.display = 'none';
        }
    }

    // Category selection filter
    function selectCategory(categoryName, element) {
        // Toggle active status of pills
        document.querySelectorAll('.category-pill').forEach(btn => btn.classList.remove('active'));
        element.classList.add('active');

        activeCategory = categoryName;
        filterMenu();
    }

    // Combined filtering (Search + Category)
    function filterMenu() {
        let searchQuery = document.getElementById('menuSearch').value.toLowerCase().trim();
        let cards = document.querySelectorAll('.food-card-container');
        let visibleCount = 0;

        cards.forEach(card => {
            let categories = card.getAttribute('data-categories').split(',');
            let name = card.getAttribute('data-name');
            let desc = card.getAttribute('data-desc');

            let matchesCategory = (activeCategory === 'All') || categories.includes(activeCategory);
            let matchesSearch = !searchQuery || name.includes(searchQuery) || desc.includes(searchQuery);

            if (matchesCategory && matchesSearch) {
                card.classList.remove('d-none');
                visibleCount++;
            } else {
                card.classList.add('d-none');
            }
        });

        // Show/hide empty state
        let emptyState = document.getElementById('emptyState');
        if (visibleCount === 0) {
            emptyState.classList.remove('d-none');
        } else {
            emptyState.classList.add('d-none');
        }
    }
</script>