<style>
    .quantity-box {
        width: 180px;
        height: 55px;
        border: 2px solid #ff6b81;
        border-radius: 20px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        margin: auto;
        background: white;
    }

    .qty-btn {
        border: none;
        background: transparent;
        color: #ff6b81;
        font-size: 35px;
        font-weight: bold;
        cursor: pointer;
    }

    .qty-input {
        width: 50px;
        border: none;
        background: transparent;
        text-align: center;
        font-size: 30px;
        font-weight: bold;
        color: #1f2937;
        outline: none;
    }</style>
    <div class="col-lg-4 col-md-6 col-sm-12">
        <div class="card h-100 shadow border-0">
            <img src="https://images.unsplash.com/photo-1506084868230-bb9d95c24759"
                 class="card-img-top"
                 style="height:250px; object-fit:cover;"><div class="card-body text-center">
            <h4>Pancakes 🥞</h4><h5 class="text-danger">₹149</h5><!-- Quantity Button --><div class="quantity-box mb-3">
            <button type="button"
                    class="qty-btn"
                    onclick="decreaseQuantity('qty1')">
                −
            </button><input type="text"
                            id="qty1"
                            value="0"
                            class="qty-input"
                            readonly><button type="button"
                         class="qty-btn"
                         onclick="increaseQuantity('qty1')">
            +
        </button>
    </div><form asp-controller="Cart"
            asp-action="AddToCart"
            method="post">
    <input type="hidden"
           name="ItemName"
           value="Pancakes" /><input type="hidden"
                              name="Price"
                              value="149" /><input type="hidden"
                         id="cartQty1"
                         name="Quantity"
                         value="0" /><button type="submit"
                    class="btn btn-danger w-100"
                    onclick="syncQuantity('qty1','cartQty1')">
    Add to Cart 🛒

</button>
</form>
</div>
</div>
</div>

<script>
    function increaseQuantity(id) {

            let qty = document.getElementById(id);

            qty.value = parseInt(qty.value) + 1;
        }

        function decreaseQuantity(id) {

            let qty = document.getElementById(id);

            if (parseInt(qty.value) > 0) {

                qty.value = parseInt(qty.value) - 1;
            }
        }

        function syncQuantity(inputId, hiddenId) {

            document.getElementById(hiddenId).value =
                document.getElementById(inputId).value;
        }
</script>

 