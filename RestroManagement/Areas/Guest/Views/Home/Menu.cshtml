@model List<RestroManagement.DbModels.FoodItem>

<style>
    .quantity-box {
        width: 180px;
        height: 55px;
        border: 2px solid #ff6b81;
        border-radius: 20px;
        display: flex;
        justify-content: space-around;
        align-items: center;
        margin: auto;
        background-color: white;
    }

    .qty-btn {
        border: none;
        background: transparent;
        color: #ff6b81;
        font-size: 35px;
        font-weight: bold;
        cursor: pointer;
        width: 40px;
        height: 40px;
    }

    .qty-input {
        width: 50px;
        border: none;
        background: transparent;
        text-align: center;
        font-size: 30px;
        font-weight: bold;
        color: #1f2937;
        outline: none;
    }

    .food-card {
        height: 100%;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.15);
        border: none;
        border-radius: 15px;
        overflow: hidden;
    }

    .food-image {
        height: 250px;
        width: 100%;
        object-fit: cover;
    }

    .food-name {
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .food-price {
        color: red;
        font-size: 22px;
        margin-bottom: 15px;
    }

    .cart-btn {
        width: 100%;
        font-size: 18px;
        font-weight: 600;
    }
</style>

<div class="row">
    @foreach (var items in Model)
    {
        <div class="col-lg-4 col-md-6 col-sm-12 mb-4">
            <div class="card food-card">

                <img src="@items.Images.FirstOrDefault()?.ImageUrl"
                     class="food-image"
                     alt="@items.Name" />

                <div class="card-body text-center">

                    <h4 class="food-name">@items.Name</h4>

                    <h5 class="food-price">
                        ₹@items.Portions.FirstOrDefault()?.Price /-
                    </h5>

                    <div class="quantity-box mb-3">
                        <button type="button"
                                class="qty-btn"
                                onclick="decreaseQuantity('qty_@items.Id')">
                            -
                        </button>

                        <input type="text"
                               id="qty_@items.Id"
                               value="0"
                               class="qty-input"
                               readonly />

                        <button type="button"
                                class="qty-btn"
                                onclick="increaseQuantity('qty_@items.Id')">
                            +
                        </button>
                    </div>

                    <form asp-controller="Cart"
                          asp-action="AddToCart"
                          method="post">

                        <input type="hidden"
                               name="ItemName"
                               value="@items.Name" />

                        <input type="hidden"
                               name="Price"
                               value="@items.Portions.FirstOrDefault()?.Price" />

                        <input type="hidden"
                               id="cartQty_@items.Id"
                               name="Quantity"
                               value="0" />


                    </form>

                </div>
            </div>
        </div>
    }
</div>

<script>
    function increaseQuantity(id) {
        let qty = document.getElementById(id);
        qty.value = parseInt(qty.value) + 1;
    }

    function decreaseQuantity(id) {
        let qty = document.getElementById(id);

        if (parseInt(qty.value) > 0) {
            qty.value = parseInt(qty.value) - 1;
        }
    }

    function syncQuantity(inputId, hiddenId) {
        document.getElementById(hiddenId).value =
            document.getElementById(inputId).value;
    }
</script>