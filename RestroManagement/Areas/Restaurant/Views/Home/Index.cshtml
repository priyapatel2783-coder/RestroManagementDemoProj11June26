@model IEnumerable<RestroManagement.DbModels.Order>
@{
    ViewData["Title"] = "Home";
}

<div class="container py-5">

    <!-- Dashboard Heading -->
    <div class="text-center mb-5">
        <h1 class="fw-bold text-danger">🍴 Restaurant Dashboard</h1>
        <p class="lead text-muted">Manage your restaurant operations easily</p>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-5">

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">@ViewBag.OrderCount</h3>
                <p>Total Orders</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">₹@ViewBag.TotalRevenue</h3>
                <p>Revenue</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold mb-0">@ViewBag.FoodItemCount</h3>
                <p>Menu Items</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="text-danger">18</h3>
                <p>Pending Orders</p>
            </div>
        </div>

    </div>

    <!-- Management Section -->
    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>📋 Manage Orders</h4>
                <p>View and update customer orders.</p>
                <a href="/Restaurant/Orders" class="btn btn-primary">
                    View Orders
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>🍔 Manage Menu</h4>
                <p>Add, edit or remove food items.</p>
                <a href="/Restaurant/FoodItems" class="btn btn-success">
                    Manage Menu
                </a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-lg border-0 text-center p-4">
                <h4>👥 Customers</h4>
                <p>Track customer details and orders.</p>
                <a asp-controller="Customers" asp-action="Index" class="btn btn-warning">
                    View Customers
                </a>
            </div>
        </div>

    </div>

    <!-- Recent Orders Table -->
    <div class="mt-5">
        <h2 class="mb-4 text-danger">Recent Orders</h2>

        <table class="table table-bordered table-hover shadow">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Food Item</th>
                    <th>Status</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                    @foreach(var order in Model)
                    {
                    <tr>
                    <td>#@order.Id</td>
                    <td>@order.CustomerName</td>
                        @if (order.Items == null || order.Items.Count == 0)
                        {
                            <td> No Items added </td>
                        }
                        else if (order.Items.Count == 1)
                        {
                            <td>
                                @order.Items.FirstOrDefault().FoodItem.Name
                            </td>
                        }
                        else
                        {
                            <td>
                                @order.Items.FirstOrDefault().FoodItem.Name + @(order.Items.Count() - 1)
                            </td>
                        }

                    <td><span class="badge bg-warning">Pending</span></td>
                    <td>@order.OrderTotal</td>
                </tr> 
               }   
            </tbody>
        </table>
    </div>

</div>