@model RestroManagement.DbModels.FoodItem

@{
    ViewData["Title"] = (Model?.Id > 0 ? "Edit" : "Create") + " Food Item";
    var allCategories = ViewBag.Categories as List<RestroManagement.DbModels.MenuCategory> ?? new List<RestroManagement.DbModels.MenuCategory>();
    var selectedCategoryIds = Model?.Categories?.Select(c => c.CategoryId).ToList() ?? new List<int>();
}
<link rel="stylesheet" href="~/css/Create.css" asp-append-version="true" />
<div class="mb-4">
    <a asp-action="Index" class="btn btn-link p-0 text-decoration-none text-muted mb-2">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
    <h2 class="fw-bold">@ViewData["Title"]</h2>
</div>

<form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")" enctype="multipart/form-data">
    <div class="row">
        <div class="col-lg-8">
            <!-- Basic Info Card -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-info-circle me-2"></i>Basic Information</h5>
                @if (Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g. Masala Dosa" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the item..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DietaryPreference" class="form-label fw-semibold"></label>
                        <select asp-for="DietaryPreference" asp-items="Html.GetEnumSelectList<RestroManagement.DbModels.DietaryPreference>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PriceCalculationMethod" class="form-label fw-semibold"></label>
                        <select asp-for="PriceCalculationMethod" asp-items="Html.GetEnumSelectList<RestroManagement.DbModels.PriceCalculationMethod>()" class="form-select"></select>
                    </div>
                </div>

                <div class="form-check form-switch mt-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsAvailable">
                    <label class="form-check-label fw-bold" asp-for="IsAvailable">Item Available for Order</label>
                </div>
            </div>

            <!-- Images Card -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-images me-2"></i>Food Images</h5>
                
                @if (Model?.Images != null && Model.Images.Any())
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold mb-3">Current Images</label>
                        <div class="d-flex flex-wrap">
                            @foreach (var img in Model.Images)
                            {
                                <div class="image-container @(img.IsPrimary ? "primary" : "")">
                                    <img src="@img.ImageUrl" alt="Food Image" />
                                    @if (img.IsPrimary) { <span class="primary-badge">Primary</span> }
                                    <div class="image-actions">
                                        @if (!img.IsPrimary)
                                        {
                                            <button type="submit" asp-action="SetPrimaryImage" asp-route-foodItemId="@Model.Id" asp-route-imageId="@img.Id" class="btn btn-sm btn-primary shadow-sm" title="Set as Primary">
                                                <i class="bi bi-star-fill"></i>
                                            </button>
                                        }
                                        <button type="submit" asp-action="DeleteImage" asp-route-id="@img.Id" class="btn btn-sm btn-danger shadow-sm" title="Delete" onclick="return confirm('Delete this image?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <hr />
                }

                <div class="mb-4">
                    <label class="form-label fw-semibold mb-3">Add New Images</label>
                    
                    <ul class="nav nav-pills mb-3" id="imageSourceTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="upload-tab" data-bs-toggle="pill" data-bs-target="#upload-content" type="button" role="tab">
                                <i class="bi bi-upload me-2"></i>Upload Files
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="url-tab" data-bs-toggle="pill" data-bs-target="#url-content" type="button" role="tab">
                                <i class="bi bi-link-45deg me-2"></i>External URLs
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content" id="imageSourceContent">
                        <!-- Upload Tab -->
                        <div class="tab-pane fade show active" id="upload-content" role="tabpanel">
                            <div class="border-dashed p-4 text-center bg-light rounded" style="border: 2px dashed #ccc;">
                                <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                                <p class="mt-2 text-muted">Select multiple images to upload</p>
                                <input type="file" name="imageFiles" id="imageFiles" class="form-control" multiple accept="image/*" onchange="handleFilePreview(this)" />
                            </div>
                            <div id="filePreviewContainer" class="d-flex flex-wrap mt-3"></div>
                        </div>

                        <!-- URL Tab -->
                        <div class="tab-pane fade" id="url-content" role="tabpanel">
                            <div id="urlInputContainer">
                                <div class="input-group mb-2">
                                    <input type="text" name="externalUrls" class="form-control" placeholder="https://example.com/image.jpg" onchange="handleUrlPreview(this)" />
                                    <button type="button" class="btn btn-outline-secondary" onclick="addUrlInput()"><i class="bi bi-plus-lg"></i></button>
                                </div>
                            </div>
                            <div id="urlPreviewContainer" class="d-flex flex-wrap mt-3"></div>
                        </div>
                    </div>

                    <div class="mt-3 d-none" id="primarySelector">
                        <label class="form-label fw-semibold">Select Primary Image from New Selection</label>
                        <select name="primaryImageIndex" id="primaryImageIndex" class="form-select w-auto">
                            <option value="0">First image in selection</option>
                        </select>
                    </div>
                </div>
            </div>

            @if (Model?.Id > 0)
            {
                <!-- Portions Card -->
                <div class="card p-4 mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold m-0"><i class="bi bi-box-seam me-2"></i>Portions & Pricing</h5>
                        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addPortionModal">
                            <i class="bi bi-plus-lg"></i> Add Portion
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Portion Name</th>
                                    <th>Price</th>
                                    <th>Cost</th>
                                    <th>Base Qty</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Portions != null && Model.Portions.Any())
                                {
                                    foreach (var p in Model.Portions)
                                    {
                                        <tr>
                                            <td class="fw-bold">@p.Name</td>
                                            <td>₹@p.Price</td>
                                            <td>₹@p.Cost</td>
                                            <td>@p.BaseQuantity</td>
                                            <td class="text-end">
                                                <button type="submit" asp-action="DeletePortion" asp-route-id="@p.Id" class="btn btn-sm text-danger" onclick="return confirm('Delete this portion?')">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="5" class="text-center text-muted py-3">No portions added yet.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <!-- Categories Card -->
            <div class="card p-4 mb-4">
                <h5 class="fw-bold mb-4"><i class="bi bi-tags me-2"></i>Menu Categories</h5>
                <div style="max-height: 400px; overflow-y: auto;" class="custom-scrollbar">
                    @foreach (var cat in allCategories)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="selectedCategories" value="@cat.Id" id="cat_@cat.Id" @(selectedCategoryIds.Contains(cat.Id) ? "checked" : "")>
                            <label class="form-check-label" for="cat_@cat.Id">
                                @cat.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="card p-4 bg-light shadow-sm sticky-top" style="top: 20px;">
                <button type="submit" class="btn btn-primary btn-lg w-100 mb-3 py-3">
                    <i class="bi bi-save2-fill me-2"></i> Save Food Item
                </button>
                <div class="d-flex justify-content-between small text-muted">
                    <span>Last Updated</span>
                    <span>@Model?.LastUpdated.ToString("g")</span>
                </div>
            </div>
        </div>
    </div>
</form>

@if (Model?.Id > 0)
{
    <!-- Portion Modal -->
    <div class="modal fade" id="addPortionModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="AddPortion">
                <input type="hidden" name="FoodItemId" value="@Model.Id" />
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Add Portion</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Portion Name (e.g. Full, 1kg)</label>
                            <input name="Name" class="form-control" placeholder="Full / Half / 500g" required />
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Price (Selling)</label>
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input name="Price" type="number" step="0.01" class="form-control" required />
                                </div>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-semibold">Cost (Internal)</label>
                                <div class="input-group">
                                    <span class="input-group-text">₹</span>
                                    <input name="Cost" type="number" step="0.01" class="form-control" required />
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Base Quantity</label>
                            <input name="BaseQuantity" type="number" step="0.01" value="1" class="form-control" required />
                            <small class="text-muted">Use 1000 for per kg pricing if proportional.</small>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4">Add Portion</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        let totalNewImages = 0;

        function updatePrimarySelector() {
            const select = $('#primaryImageIndex');
            const total = totalNewImages + (parseInt("@(Model?.Images?.Count ?? 0)"));
            
            select.empty();
            // Start from existing images if any
            for (let i = 0; i < total; i++) {
                const label = i < (parseInt("@(Model?.Images?.Count ?? 0)")) ? `Existing Image ${i + 1}` : `New Image ${i - (parseInt("@(Model?.Images?.Count ?? 0)")) + 1}`;
                select.append(`<option value="${i}">${label}</option>`);
            }
            
            if (total > 1) $('#primarySelector').removeClass('d-none');
            else $('#primarySelector').addClass('d-none');
        }

        function handleFilePreview(input) {
            const container = $('#filePreviewContainer');
            container.empty();
            if (input.files) {
                Array.from(input.files).forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        container.append(`<div class="image-container"><img src="${e.target.result}" /><span class="primary-badge bg-secondary">New Upload</span></div>`);
                    }
                    reader.readAsDataURL(file);
                });
                totalNewImages = input.files.length + $('.url-preview-item').length;
                updatePrimarySelector();
            }
        }

        function handleUrlPreview(input) {
            const container = $('#urlPreviewContainer');
            container.empty();
            $('input[name="externalUrls"]').each(function() {
                const url = $(this).val();
                if (url) {
                    container.append(`<div class="image-container url-preview-item"><img src="${url}" /><span class="primary-badge bg-secondary">New URL</span></div>`);
                }
            });
            totalNewImages = $('#imageFiles')[0].files.length + $('.url-preview-item').length;
            updatePrimarySelector();
        }

        function addUrlInput() {
            $('#urlInputContainer').append(`
                <div class="input-group mb-2">
                    <input type="text" name="externalUrls" class="form-control" placeholder="https://example.com/image.jpg" onchange="handleUrlPreview(this)" />
                    <button type="button" class="btn btn-outline-danger" onclick="$(this).parent().remove(); handleUrlPreview();"><i class="bi bi-dash-lg"></i></button>
                </div>
            `);
        }
    </script>
}
