@model IEnumerable<RestroManagement.DbModels.MenuCategory>

@{
    ViewData["Title"] = "Menu Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold m-0">Menu Categories</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add New Category
    </a>
</div>

<div class="card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 80px;">Order</th>
                    <th>Category Name</th>
                    <th>Image URL</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td><span class="badge bg-secondary">@item.DisplayOrder</span></td>
                    <td class="fw-semibold">@item.Name</td>
                    <td class="text-muted small">@(string.IsNullOrEmpty(item.ImageUrl) ? "No Image" : item.ImageUrl)</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" 
                           onclick="return confirm('Are you sure you want to delete this category?')">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
